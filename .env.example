# Copy this to .env and fill in your local values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/data_pipeline

# App
ENVIRONMENT=development
LOG_LEVEL=DEBUG
LOG_SQLALCHEMY_LEVEL=WARNING
LOG_HTTPX_LEVEL=WARNING
LOG_ASYNCIO_LEVEL=WARNING

# Documentation Authentication (optional)
# Leave empty to allow public access to /docs, /redoc, /openapi.json
# Set both to enable HTTP Basic Auth protection on docs endpoints
DOCS_USERNAME=admin
DOCS_PASSWORD=changeme

# API Authentication — v1 (Token-based + Session)
API_V1_BEARER_TOKEN=dev-secret-bearer-token
TOKEN_EXPIRY_HOURS=24

# API Authentication — v2 (JWT)
JWT_SECRET=your-super-secret-key-at-least-32-characters-long-change-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Redis (optional)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# Celery (optional)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# External APIs
OPENAI_API_KEY=sk-test-xxxxxxxx

# OpenTelemetry (distributed tracing → Jaeger)
# Set OTEL_ENABLED=true when running with docker compose (Jaeger is included)
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=data-pipeline-ingestor
